Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Section", " ", "2", " ", "Plots", " ", "and", " ", "Rosenblatt", " ", 
    "Estimator"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Normal", 
    RowBox[{"(", 
     RowBox[{"5", ",", "1"}], ")"}], " ", "density", " ", "and", " ", 
    "plot"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "123", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Norm51", "=", 
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"5", ",", "1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DataN51", "=", 
     RowBox[{"RandomVariate", "[", 
      RowBox[{"Norm51", ",", "100"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"PlotN51", " ", "=", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"PDF", "[", 
         RowBox[{"Norm51", ",", "x"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
        RowBox[{"PlotLabel", "->", "\"\<Normal Distribution PDF\>\""}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<Probability Density\>\""}], "}"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"{", "\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"f\", \"TI\"], \"(\", 
StyleBox[\"x\", \"TI\"], \")\"}], TraditionalForm], \"errors\" -> {}, \"input\
\" -> \"f (x)\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", 
          "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Filling", "->", "Axis"}]}], "]"}], ",", 
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"Transpose", "@", 
         RowBox[{"{", 
          RowBox[{"DataN51", ",", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0", ",", 
             RowBox[{"Length", "[", "DataN51", "]"}]}], "]"}]}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{"Red", ",", 
           RowBox[{"Opacity", "[", "0.9", "]"}]}], "}"}]}]}], "]"}]}], 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"CDF", " ", "vs", " ", "Empirical", " ", "CDF", " ", "plot"}], ",",
      " ", 
     RowBox[{
     "where", " ", "we", " ", "use", " ", "ListStepPlot", " ", "to", " ", 
      "make", " ", "the", " ", "ECDF", " ", "with", " ", "the", " ", "data", " ",
       "points", " ", "defined", " ", "below"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FnData", "=", 
     RowBox[{"Transpose", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sort", "[", "DataN51", "]"}], ",", 
        RowBox[{
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "DataN51", "]"}], "]"}], "/", 
         RowBox[{"Length", "[", "DataN51", "]"}]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FnDataExtended", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], "}"}], ",", "FnData", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"10", ",", 
           RowBox[{"FnData", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"10", ",", "1"}], "}"}]}], "}"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "this", " ", "extension", " ", "was", " ", "necessary", " ", "to", " ", 
     "include", " ", "the", " ", 
     RowBox[{"(", 
      RowBox[{"0", ",", "0"}], ")"}], " ", "and", " ", 
     RowBox[{"(", 
      RowBox[{"1", ",", "1"}], ")"}], " ", "points", " ", "for", " ", 
     "ListStepPlot"}], "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"PlotN51CDF", " ", "=", " ", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"CDF", "[", 
         RowBox[{"Norm51", ",", "x"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
        RowBox[{
        "PlotLabel", "->", "\"\<Normal Distribution CDF with ECDF\>\""}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<Probability Density\>\""}], "}"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"{", "\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"F\", \"TI\"], \"(\", 
StyleBox[\"x\", \"TI\"], \")\"}], TraditionalForm], \"errors\" -> {}, \"input\
\" -> \"F(x)\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", 
          "}"}]}]}], "]"}], ",", 
      RowBox[{"ListStepPlot", "[", 
       RowBox[{"FnDataExtended", ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{"Red", ",", 
           RowBox[{"Thickness", "[", "0.003", "]"}]}], "}"}]}], ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}]}], ",", " ", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"{", "\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
SubscriptBox[
StyleBox[\"F\", \"TI\"], 
StyleBox[\"n\", \"TI\"]], \"(\", 
StyleBox[\"x\", \"TI\"], \")\"}], TraditionalForm], \"errors\" -> {}, \"input\
\" -> \"F_n (x)\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", 
          "}"}]}]}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Rosenblatt", " ", "Estimator", " ", "Construction", " ", "and", " ", 
      "plot"}], ",", " ", 
     RowBox[{
     "which", " ", "is", " ", "equivalent", " ", "to", " ", "the", " ", "KDE",
       " ", "on", " ", "R", " ", "with", " ", "the", " ", "rectangular", " ", 
      "kernel"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RectKer", "[", 
     RowBox[{"u_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Piecewise", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "2"}], ",", 
         RowBox[{
          RowBox[{"Abs", "[", "u", "]"}], "<=", "1"}]}], "}"}], "}"}], ",", 
      "0"}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"KDERosen", "[", 
      RowBox[{
       RowBox[{"x_", "?", "NumericQ"}], ",", "h_", ",", "data_"}], "]"}], " ",
      ":=", " ", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"h", "*", 
        RowBox[{"Length", "[", "data", "]"}]}]], 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"RectKer", "[", 
         FractionBox[
          RowBox[{"xi", "-", "x"}], "h"], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"xi", ",", "data"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"RosenblattPlot", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"KDERosen", "[", 
       RowBox[{"x", ",", "1", ",", " ", "DataN51"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<Rosenblatt Estimator\>\""}], ",", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", "\"\<Probability Density\>\""}], "}"}]}], ",", 
      RowBox[{"Filling", "->", "None"}], ",", 
      RowBox[{"PlotStyle", "->", "Thin"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Probability", " ", "Region", " ", "Gamma", " ", "Density", " ", "Plot"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dist", "=", 
     RowBox[{"GammaDistribution", "[", 
      RowBox[{"4", ",", "0.8"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Region", " ", "A", " ", "of", " ", "interest"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"a", "=", "1.5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"b", "=", "4.2"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Blue", " ", "colour", " ", "seen", " ", "in", " ", "the", " ", "other", " ",
      "plots", " ", "of", " ", "this", " ", "section"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"blue", "=", 
     RowBox[{
      RowBox[{"ColorData", "[", "97", "]"}], "[", "1", "]"}]}], ";"}], " ", 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Used", " ", "to", " ", "plot", " ", "the", " ", "probability", " ", 
     "region", " ", "in", " ", "the", " ", "below", " ", "plot"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"regionPts", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"a", ",", "0"}], "}"}], "}"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"PDF", "[", 
            RowBox[{"dist", ",", "x"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b", ",", "0.01"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"b", ",", "0"}], "}"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"PlotGamma", " ", "=", " ", 
    RowBox[{"Legended", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"PDF", "[", 
         RowBox[{"dist", ",", "x"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{"blue", ",", "Thick"}], "}"}]}], ",", 
        RowBox[{"Axes", "->", "True"}], ",", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<Density\>\""}], "}"}]}], ",", 
        RowBox[{"PlotRange", "->", "All"}], ",", 
        RowBox[{"Epilog", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Directive", "[", 
              RowBox[{
               RowBox[{"Opacity", "[", "0.3", "]"}], ",", "blue"}], "]"}], ",", 
             RowBox[{"EdgeForm", "[", "None", "]"}], ",", 
             RowBox[{"Polygon", "[", "regionPts", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"blue", ",", "Thin", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"a", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"a", ",", 
                  RowBox[{"PDF", "[", 
                   RowBox[{"dist", ",", "a"}], "]"}]}], "}"}]}], "}"}], "]"}],
              ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"b", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"b", ",", 
                  RowBox[{"PDF", "[", 
                   RowBox[{"dist", ",", "b"}], "]"}]}], "}"}]}], "}"}], 
              "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Directive", "[", 
              RowBox[{"Red", ",", 
               RowBox[{"Opacity", "[", "1", "]"}], ",", "Thick"}], "]"}], ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"a", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"b", ",", "0"}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Directive", "[", 
              RowBox[{"Red", ",", 
               RowBox[{"Opacity", "[", "1", "]"}]}], "]"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{"\"\<A\>\"", ",", "14"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"a", "+", "b"}], ")"}], "/", "2"}], ",", "0.01"}], 
                "}"}]}], "]"}]}], "}"}]}], "}"}]}]}], "]"}], ",", 
      RowBox[{"SwatchLegend", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Directive", "[", 
          RowBox[{
           RowBox[{"Opacity", "[", "0.3", "]"}], ",", "blue"}], "]"}], "}"}], 
        ",", 
        RowBox[{"{", "\"\<P(A)\>\"", "}"}]}], "]"}]}], "]"}]}]}]}]], "Input",
